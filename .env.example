# Datasheet site — independent database (new Supabase project)
DATABASE_URL="postgresql://postgres.[ref]:[pwd]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[ref]:[pwd]@aws-0-[region].pooler.supabase.com:5432/postgres"

# NextAuth — datasheet admin login
AUTH_SECRET="run: openssl rand -base64 32"
AUTH_URL="http://localhost:3001"

# Main site — where product list is synced from (read-only)
MAIN_SITE_URL="http://localhost:3000"

# Cloudflare R2 (S3-compatible) — material storage
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="datasheet-assets"
# Public base URL of the R2 bucket (r2.dev domain or custom domain)
R2_PUBLIC_URL="https://pub-xxxx.r2.dev"

# This site's own public base URL — used to compose QR code links
NEXT_PUBLIC_SITE_URL="http://localhost:3001"
